<?xml version="1.0" encoding="utf-8"?>
<!--
    Resource shrinking keep rules.
    default_web_client_id is generated by the google-services plugin from
    google-services.json and is looked up dynamically via getIdentifier()
    in LoginFeature. Without this rule, resource shrinking removes it
    from the release build, breaking Google Sign-In.
-->
<resources xmlns:tools="http://schemas.android.com/tools"
    tools:keep="@string/default_web_client_id" />

