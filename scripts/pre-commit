#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────
# Pre-commit hook: Ktlint auto-format & check
# Auto-formats staged Kotlin files, re-stages them, and only
# blocks the commit if unfixable issues remain.
#
# Unstaged changes are stashed before formatting to prevent
# the project-wide ktlintFormat from modifying unrelated files.
# Output is NEVER suppressed — errors are shown in full.
# ─────────────────────────────────────────────────────────────
set -euo pipefail

# Colors for terminal output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No color

# Check if there are staged Kotlin files
STAGED_KT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.kts?$' || true)

if [ -z "$STAGED_KT_FILES" ]; then
    echo -e "${GREEN}✓ No Kotlin files staged — skipping ktlint${NC}"
    exit 0
fi

FILE_COUNT=$(echo "$STAGED_KT_FILES" | wc -l | tr -d ' ')
echo -e "${YELLOW}⏳ Kotlin file(s) staged (${FILE_COUNT}) — running ktlint auto-format...${NC}"
echo ""

# ── Step 1: Stash unstaged changes ──────────────────────────
# This ensures ktlintFormat only sees what is being committed.
# Using --keep-index preserves the staged snapshot in the worktree.
HAS_UNSTAGED=false
if ! git diff --quiet; then
    HAS_UNSTAGED=true
    git stash push --keep-index --quiet -m "pre-commit: unstaged changes"
fi

# Ensure we always restore unstaged changes, even on failure
restore_stash() {
    if [ "$HAS_UNSTAGED" = true ]; then
        git stash pop --quiet 2>/dev/null || true
    fi
}
trap restore_stash EXIT

# ── Step 2: Auto-format ─────────────────────────────────────
./gradlew ktlintFormat --daemon 2>&1 || true

# ── Step 3: Re-stage any files that were modified by the formatter
echo "$STAGED_KT_FILES" | while IFS= read -r file; do
    if [ -f "$file" ]; then
        git add "$file"
    fi
done

# ── Step 4: Verify — fail only if unfixable issues remain ───
if ./gradlew ktlintCheck --daemon 2>&1; then
    echo ""
    echo -e "${GREEN}✓ Ktlint passed — all files are properly formatted${NC}"
    exit 0
else
    EXIT_CODE=$?
    echo ""
    echo -e "${RED}✗ Ktlint found issues that could not be auto-fixed (see above)${NC}"
    echo ""
    echo -e "${YELLOW}💡 Fix manually and retry, or skip hook: git commit --no-verify${NC}"
    echo ""
    exit $EXIT_CODE
fi

