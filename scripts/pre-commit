#!/bin/sh
# Pre-commit hook: runs Ktlint and Detekt checks before allowing a commit.
# Install via: ./gradlew installGitHooks

echo "🔍 Running pre-commit checks..."

# Run Ktlint formatting check
echo "  ▸ Ktlint check..."
./gradlew ktlintCheck --daemon --quiet 2>/dev/null
KTLINT_EXIT=$?

if [ $KTLINT_EXIT -ne 0 ]; then
    echo ""
    echo "❌ Ktlint found formatting issues."
    echo "   Run './gradlew ktlintFormat' to fix them automatically."
    echo ""
    exit 1
fi

# Run Detekt static analysis
echo "  ▸ Detekt analysis..."
./gradlew detekt --daemon --quiet 2>/dev/null
DETEKT_EXIT=$?

if [ $DETEKT_EXIT -ne 0 ]; then
    echo ""
    echo "❌ Detekt found code quality issues."
    echo "   Check the reports in each module's build/reports/detekt/ directory."
    echo ""
    exit 1
fi

echo "✅ All pre-commit checks passed."

