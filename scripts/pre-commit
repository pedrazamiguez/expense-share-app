#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────
# Pre-commit hook: Ktlint formatting check
# Runs ktlint on the entire project when Kotlin files are staged.
# Output is NEVER suppressed — errors are shown in full.
# ─────────────────────────────────────────────────────────────
set -euo pipefail

# Colors for terminal output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No color

# Check if there are staged Kotlin files
STAGED_KT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.kts?$' || true)

if [ -z "$STAGED_KT_FILES" ]; then
    echo -e "${GREEN}✓ No Kotlin files staged — skipping ktlint${NC}"
    exit 0
fi

FILE_COUNT=$(echo "$STAGED_KT_FILES" | wc -l | tr -d ' ')
echo -e "${YELLOW}⏳ Running ktlint on ${FILE_COUNT} staged Kotlin file(s)...${NC}"
echo ""

# Run ktlint check — FULL OUTPUT, never piped to /dev/null
if ./gradlew ktlintCheck --daemon 2>&1; then
    echo ""
    echo -e "${GREEN}✓ Ktlint passed — all files are properly formatted${NC}"
    exit 0
else
    EXIT_CODE=$?
    echo ""
    echo -e "${RED}✗ Ktlint found formatting issues (see above)${NC}"
    echo ""
    echo -e "${YELLOW}💡 Auto-fix:  ./gradlew ktlintFormat${NC}"
    echo -e "${YELLOW}💡 Skip hook: git commit --no-verify${NC}"
    echo ""
    exit $EXIT_CODE
fi

